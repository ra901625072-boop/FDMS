# =========================================================================
# FAMILY DOCUMENT MANAGEMENT SYSTEM - CONFIGURATION VARIABLES
# Rename this file to '.env' inside the backend folder.
# =========================================================================

# App Environment Settings
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8000

# SQLite Database Connection String
# e.g., sqlite:///./family_documents.db (Default)
# Note: For SQLite, the database file will be auto-created on start.
DATABASE_URL=sqlite:///./family_documents.db

# JWT Token Security Variables
# Use a strong, unique secret key. You can generate one using:
# openssl rand -hex 32
JWT_SECRET=super-secret-family-document-vault-key-1234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Cloud Service Account Settings (Recommended)
# Obtain a Service Account JSON key from the Google Cloud Console
# Place the file in the backend directory (default: service-account.json)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
# Create a Google Drive folder and share it with your Service Account email as Editor
# Paste the Google Drive folder ID here:
GOOGLE_FOLDER_ID=your-shared-folder-id-here

# Google Cloud OAuth Credentials Settings (Deprecated)
# GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# GOOGLE_REFRESH_TOKEN=your-google-refresh-token-here

